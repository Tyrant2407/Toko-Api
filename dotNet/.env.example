# ─── Backend Environment Variables ─────────────────────────────────────────────
# These are set via environment variables in production (Docker / cloud).
# For local development, appsettings.Development.json is used instead.

# Database connection
ConnectionStrings__DefaultConnection=Server=localhost;Database=toko_db;User=root;Password=YourPasswordHere;

# JWT Settings
Jwt__Key=BelajarNetSuperSecretKey_ChangeMeInProduction_2026!
Jwt__Issuer=TokoApi
Jwt__Audience=TokoFrontend

# CORS — comma-separated list of allowed origins
Cors__AllowedOrigins=http://localhost:3000

# Low stock alert threshold
LowStockThreshold=5

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production
