# ─── BelajarNet Environment Variables Template ────────────────────────────────
# Copy this file to `.env` (gitignored) and fill in your values.
# Never commit the actual .env file to version control.

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=toko_db

# ── JWT (min 32 characters for HS256 security) ────────────────────────────────
JWT_KEY=BelajarNetSuperSecretKey_ReplaceMe_AtLeast32Chars!

# ── CORS (comma-separated) ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5174/api
